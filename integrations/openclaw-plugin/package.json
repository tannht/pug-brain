{
  "name": "pug-brain-openclaw",
  "version": "2.27.5",
  "description": "PugBrain plugin for OpenClaw — brain-inspired persistent memory for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "id": "pug-brain",
    "extensions": [
      "./dist/index.js"
    ],
    "source": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "postinstall": "npm run build 2>/dev/null || true",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "pug-brain",
    "pugbrain",
    "ai-agent",
    "persistent-memory"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tannht/pug-brain"
  },
  "files": [
    "src/",
    "dist/",
    "openclaw.plugin.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
